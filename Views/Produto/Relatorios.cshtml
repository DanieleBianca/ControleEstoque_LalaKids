<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; display: flex; min-height: 100vh; }

    .sidebar {
        width: 220px;
        min-height: 100vh;
        background-color: #BDD7E7;
        display: flex;
        flex-direction: column;
        padding: 28px 16px;
        position: fixed;
        top: 0; left: 0;
        border-right: 1px solid rgba(0,0,0,0.06);
    }
    .sidebar-logo { text-align: center; margin-bottom: 40px; }
    .sidebar-logo img { width: 140px; height: auto; object-fit: contain; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .btn-sidebar {
        background-color: transparent;
        color: #1a1a1a; /* azul escuro legível sobre o fundo azul */
        border: none;
        border-radius: 8px;
        padding: 10px 14px;
        font-weight: 500;
        font-size: 0.9rem;
        text-align: left;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
    }
    .btn-sidebar:hover {
        background-color: rgba(255,255,255,0.35); /* branco translúcido no hover */
        color: #1a1a1a;
    }
    .btn-sidebar.ativo {
        background-color: rgba(255,255,255,0.5); /* mais opaco no ativo */
        color: #1a3a50;
        font-weight: 700;
    }
    .btn-sidebar.ativo:hover { color: #1a3a50; }

    .sidebar-divider { border: none; border-top: 1px solid rgba(0,0,0,0.1); margin: 20px 0; }
    .sidebar-footer { display: flex; flex-direction: column; gap: 2px; }
    .btn-sidebar-link {
        background: none;
        border: none;
        padding: 10px 14px;
        text-align: left;
        color: #2a4a5e;
        font-size: 0.9rem;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
        font-weight: 500;
        border-radius: 8px;
    }
    .btn-sidebar-link:hover { background-color: rgba(255,255,255,0.35); color: #1a1a1a; }
    .btn-sair { color: #a83210 !important; }
    .btn-sair:hover { background-color: rgba(242,72,34,0.12) !important; color: #a83210 !important; }
    .main-content {
        margin-left: 260px;
        padding: 48px;
        flex: 1;
        width: calc(100% - 260px);
    }
    .main-titulo {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 8px;
    }
    .main-subtitulo {
        color: #777;
        font-size: 0.95rem;
        margin-bottom: 40px;
        font-weight: 400;
    }

    /* grid de cards */
    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 24px;
        max-width: 900px;
    }
    .card-relatorio {
        background: white;
        border-radius: 16px;
        padding: 28px 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        text-decoration: none;
        display: block;
        border-top: 4px solid transparent;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        position: relative;
        overflow: hidden;
    }
    .card-relatorio:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }
    .card-relatorio.azul { border-top-color: #2E6A8E; }
    .card-relatorio.verde { border-top-color: #14ae5c; }
    .card-relatorio.laranja { border-top-color: #F24822; }
    .card-relatorio.cinza { border-top-color: #6c757d; }

    .card-titulo {
        font-weight: 700;
        font-size: 1rem;
        color: #1a1a1a;
        margin-bottom: 8px;
    }
    .card-descricao {
        font-size: 0.85rem;
        color: #888;
        font-weight: 400;
        line-height: 1.5;
    }
    .card-seta {
        position: absolute;
        bottom: 20px;
        right: 20px;
        font-size: 1.1rem;
        color: #ccc;
        transition: color 0.2s ease, right 0.2s ease;
    }
    .card-relatorio:hover .card-seta {
        color: #2E6A8E;
        right: 16px;
    }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.jpg" alt="Logo" onerror="this.style.display='none'" />
    </div>
    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar ativo">Relatórios</a>
    </nav>
    <hr class="sidebar-divider" />
    <div class="sidebar-footer">
        <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
        <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
    </div>
</div>

<div class="main-content">
    <div class="main-titulo">Relatórios</div>
    <div class="main-subtitulo">Selecione um relatório para visualizar</div>

    <div class="cards-grid">

        <a href="/produto/relatorioHistoricoMovimentacoes" class="card-relatorio azul">
            <div class="card-titulo">Histórico de Movimentações</div>
            <div class="card-descricao">Visualize todas as entradas e saídas registradas no sistema.</div>
        </a>

        <a href="/produto/relatorioEstoqueBaixo" class="card-relatorio laranja">
            <div class="card-titulo">Estoque Baixo</div>
            <div class="card-descricao">Produtos com tamanhos com 2 unidades ou menos — hora de repor.</div>
        </a>

    </div>
</div>