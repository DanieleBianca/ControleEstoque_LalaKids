@using System.Linq

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; display: flex; min-height: 100vh; }

    .sidebar {
        width: 260px;
        min-height: 100vh;
        background-color: #BDD7E7;
        display: flex;
        flex-direction: column;
        padding: 24px 16px;
        position: fixed;
        top: 0; left: 0;
        box-shadow: 2px 0 8px rgba(0,0,0,0.08);
    }
    .sidebar-logo { text-align: center; margin-bottom: 32px; }
    .sidebar-logo img { height: 80px; object-fit: contain; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .btn-sidebar {
        background-color: white;
        color: #1a1a1a;
        border: none;
        border-radius: 8px;
        padding: 12px 16px;
        font-weight: 600;
        text-align: left;
        text-decoration: none;
        display: block;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }
    .btn-sidebar:hover { background-color: #e8f0f5; transform: translateX(3px); color: #1a1a1a; }
    .btn-sidebar.ativo { background-color: #2E6A8E; color: white; }
    .btn-sidebar.ativo:hover { color: white; }
    .sidebar-divider { border: none; border-top: 1px solid rgba(0,0,0,0.15); margin: 16px 0; }
    .sidebar-footer { display: flex; flex-direction: column; gap: 10px; }
    .btn-sidebar-link {
        background: none; border: none; padding: 8px 4px;
        text-align: left; color: #1a1a1a; font-size: 0.95rem;
        text-decoration: none; display: block;
        transition: color 0.2s ease; font-weight: 500;
    }
    .btn-sidebar-link:hover { color: #2E6A8E; }
    .btn-sair { color: #F24822; }
    .btn-sair:hover { color: #c03518; }

    .main-content {
        margin-left: 260px;
        padding: 48px;
        flex: 1;
        width: calc(100% - 260px);
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .page-header {
        width: 100%;
        max-width: 750px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
    }
    .main-titulo { font-size: 1.8rem; font-weight: 700; }
    .main-subtitulo { color: #888; font-size: 0.9rem; margin-bottom: 32px; width: 100%; max-width: 750px; }

    .btn-voltar {
        background-color: white;
        color: #1a1a1a;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 9px 20px;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
        transition: background-color 0.2s ease, border-color 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .btn-voltar:hover { background-color: #f0f0ee; border-color: #ccc; color: #1a1a1a; }

    .card-tabela {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        width: 100%;
        max-width: 750px;
        overflow: hidden;
    }
    .tabela-busca { padding: 20px 28px 16px; border-bottom: 1px solid #f0f0f0; }
    .input-busca {
        background-color: #f8f8f6;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 9px 14px;
        font-family: 'Poppins', sans-serif;
        font-size: 0.88rem;
        color: #1a1a1a;
        width: 100%;
        transition: border-color 0.2s ease;
    }
    .input-busca:focus { outline: none; border-color: #2E6A8E; background-color: white; }

    table { width: 100%; border-collapse: collapse; }
    thead tr { background-color: #f4f8fb; }
    th {
        padding: 13px 28px;
        font-size: 0.75rem;
        font-weight: 700;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        text-align: left;
        border-bottom: 1px solid #f0f0f0;
    }
    td { padding: 14px 28px; font-size: 0.9rem; border-bottom: 1px solid #f8f8f6; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr { transition: background-color 0.15s ease; }
    tbody tr:hover { background-color: #f9fbfd; }

    .codigo-badge {
        display: inline-block;
        background-color: #f0f6fa;
        color: #2E6A8E;
        border-radius: 6px;
        padding: 3px 10px;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.03em;
    }
    .btn-historico {
        background-color: #2E6A8E;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 7px 16px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        transition: background-color 0.2s ease, transform 0.1s ease;
        display: inline-block;
    }
    .btn-historico:hover { background-color: #245a7a; transform: translateY(-1px); color: white; }

    .alerta-info {
        background-color: #f0f6fa;
        color: #2E6A8E;
        border: 1px solid #bdd7e7;
        border-radius: 8px;
        padding: 16px 20px;
        font-size: 0.9rem;
        width: 100%;
        max-width: 750px;
    }
    </style>

    <div class="sidebar">
        <div class="sidebar-logo">
            <img src="/images/logo.png" alt="Logo" onerror="this.style.display='none'" />
        </div>
        <nav class="sidebar-nav">
            <a href="/produto/index" class="btn-sidebar">Estoque</a>
            <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
            <a href="/produto/movimentar" class="btn-sidebar">Movimentar Estoque</a>
            <a href="/produto/relatorios" class="btn-sidebar ativo">Relatórios</a>
        </nav>
        <hr class="sidebar-divider" />
        <div class="sidebar-footer">
            @if (Context.Session.GetString("UsuarioTipo") == "admin")
            {
                <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
            }
            @if (Context.Session.GetString("UsuarioTipo") != "admin")
            {
                <a href="/Usuario/TrocarSenha" class="btn-sidebar-link">Trocar Senha</a>
            }
            <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
        </div>
    </div>

<div class="main-content">
    <div class="page-header">
        <div class="main-titulo">Histórico por Produto</div>
        <a href="/produto/relatorios" class="btn-voltar">Voltar</a>
    </div>
    <div class="main-subtitulo">Selecione um produto para visualizar o histórico de movimentações</div>

    @if (Model == null)
    {
        <div class="alerta-info">Nenhum produto cadastrado ainda.</div>
    }
    else
    {
        <div class="card-tabela">
            <div class="tabela-busca">
                <input class="input-busca" type="text" placeholder="Buscar por nome ou código..."
                       oninput="filtrarTabela(this.value)" />
            </div>
            <table id="tabelaProdutos">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Código de Barras</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.Nome</td>
                            <td><span class="codigo-badge">@p.CodigoBarras</span></td>
                            <td style="text-align:right">
                                <a href="/produto/relatorioHistoricoPorProduto?id=@p.Id" class="btn-historico">
                                    Ver Histórico
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<script>
function filtrarTabela(termo) {
    const linhas = document.querySelectorAll('#tabelaProdutos tbody tr');
    const t = termo.toLowerCase();
    linhas.forEach(tr => {
        tr.style.display = tr.textContent.toLowerCase().includes(t) ? '' : 'none';
    });
}
</script>