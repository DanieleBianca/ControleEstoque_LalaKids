<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; display: flex; min-height: 100vh; }

    .sidebar {
        width: 220px;
        min-height: 100vh;
        background-color: #BDD7E7;
        display: flex;
        flex-direction: column;
        padding: 28px 16px;
        position: fixed;
        top: 0; left: 0;
        border-right: 1px solid rgba(0,0,0,0.06);
    }
    .sidebar-logo { text-align: center; margin-bottom: 40px; }
    .sidebar-logo img { width: 140px; height: auto; object-fit: contain; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .btn-sidebar {
        background-color: transparent;
        color: #1a1a1a; /* azul escuro legível sobre o fundo azul */
        border: none;
        border-radius: 8px;
        padding: 10px 14px;
        font-weight: 500;
        font-size: 0.9rem;
        text-align: left;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
    }
    .btn-sidebar:hover {
        background-color: rgba(255,255,255,0.35); /* branco translúcido no hover */
        color: #1a1a1a;
    }
    .btn-sidebar.ativo {
        background-color: rgba(255,255,255,0.5); /* mais opaco no ativo */
        color: #1a3a50;
        font-weight: 700;
    }
    .btn-sidebar.ativo:hover { color: #1a3a50; }

    .sidebar-divider { border: none; border-top: 1px solid rgba(0,0,0,0.1); margin: 20px 0; }
    .sidebar-footer { display: flex; flex-direction: column; gap: 2px; }
    .btn-sidebar-link {
        background: none;
        border: none;
        padding: 10px 14px;
        text-align: left;
        color: #2a4a5e;
        font-size: 0.9rem;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
        font-weight: 500;
        border-radius: 8px;
    }
    .btn-sidebar-link:hover { background-color: rgba(255,255,255,0.35); color: #1a1a1a; }
    .btn-sair { color: #a83210 !important; }
    .btn-sair:hover { background-color: rgba(242,72,34,0.12) !important; color: #a83210 !important; }

    .main-content {
        margin-left: 260px;
        padding: 48px;
        flex: 1;
        width: calc(100% - 260px);
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .main-titulo { font-size: 1.8rem; font-weight: 700; margin-bottom: 4px; text-align: center; width: 100%; }
    .main-subtitulo { color: #888; font-size: 0.9rem; font-weight: 400; text-align: center; margin-bottom: 32px; width: 100%; }

    .card-form {
        background: white;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        width: 100%;
        max-width: 650px;
    }
    .form-control {
        background-color: #f8f8f6;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 10px 14px;
        color: #1a1a1a;
        width: 100%;
        transition: border-color 0.2s ease;
    }
    .form-control:focus { outline: none; border-color: #2E6A8E; background-color: white; }
    .form-label { font-weight: 600; font-size: 0.85rem; color: #666; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.04em; }
    .secao-titulo {
        font-weight: 700;
        font-size: 0.85rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin: 28px 0 12px 0;
        padding-bottom: 8px;
        border-bottom: 1px solid #f0f0f0;
    }

    /* radio tipo movimentação */
    .radio-group { display: flex; gap: 12px; margin-top: 8px; }
    .radio-option {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        font-weight: 500;
        font-size: 0.9rem;
        background-color: #f8f8f6;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 10px 20px;
        transition: all 0.2s ease;
    }
    .radio-option:has(input:checked) {
        background-color: #e8f0f5;
        border-color: #2E6A8E;
        color: #2E6A8E;
    }
    .radio-option input { cursor: pointer; accent-color: #2E6A8E; }

    .alerta-erro {
        background-color: #fdecea;
        color: #F24822;
        border: 1px solid #F24822;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 16px;
        font-weight: 600;
        width: 100%;
        max-width: 650px;
    }
    .alerta-sucesso {
        background-color: #e8f5e9;
        color: #14ae5c;
        border: 1px solid #14ae5c;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 16px;
        font-weight: 600;
        width: 100%;
        max-width: 650px;
    }
    .btn-adicionar {
        background-color: transparent;
        color: #2E6A8E;
        border: 1px dashed #2E6A8E;
        border-radius: 8px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: background-color 0.2s ease;
        margin-bottom: 28px;
        width: 100%;
    }
    .btn-adicionar:hover { background-color: #f0f6fa; }
    .acoes { display: flex; align-items: center; gap: 16px; margin-top: 8px; }
    .btn-confirmar {
        background-color: #2E6A8E;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 36px;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        transition: background-color 0.2s ease, transform 0.1s ease;
        cursor: pointer;
    }
    .btn-confirmar:hover { background-color: #245a7a; transform: translateY(-1px); color: white; }
    .link-cancelar {
        color: #aaa;
        text-decoration: none;
        font-size: 0.88rem;
        transition: color 0.2s ease;
    }
    .link-cancelar:hover { color: #555; text-decoration: underline; }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.jpg" alt="Logo" onerror="this.style.display='none'" />
    </div>
    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar ativo">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar">Relatórios</a>
    </nav>
    <hr class="sidebar-divider" />
    <div class="sidebar-footer">
        <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
        <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
    </div>
</div>

<div class="main-content">
    <div class="main-titulo">Movimentar Estoque</div>
    <div class="main-subtitulo">Registre entradas e saídas de produtos</div>

    @if (TempData["Erro"] != null)
    {
        <div class="alerta-erro">@TempData["Erro"]</div>
    }

    @if (TempData["Sucesso"] != null)
    {
        <div class="alerta-sucesso">@TempData["Sucesso"]</div>
    }

    <div class="card-form">
        <form action="/produto/movimentar" method="POST">

            <div class="mb-4">
                <label class="form-label">Tipo de Movimentação</label>
                <div class="radio-group">
                    <label class="radio-option">
                        <input type="radio" name="tipo" value="entrada" id="entrada" checked />
                        Entrada
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="tipo" value="saida" id="saida" />
                        Saída
                    </label>
                </div>
            </div>

            <p class="secao-titulo">Produtos*</p>
            <div id="itens">
                <div class="d-flex gap-2 mb-2">
                    <input class="form-control" name="CodigosBarras[0]" placeholder="Código de Barras" required />
                    <input class="form-control" name="Tamanhos[0]" placeholder="Tamanho" required />
                    <input class="form-control" name="Quantidades[0]" type="number" min="1" placeholder="Qtd" required />
                </div>
            </div>

            <button type="button" class="btn-adicionar" onclick="adicionarItem()">+ Adicionar produto</button>

            <div class="acoes">
                <button type="submit" class="btn-confirmar">Confirmar</button>
                <a href="/produto/index" class="link-cancelar">Cancelar</a>
            </div>

        </form>
    </div>
</div>

<script>
    var contador = 1;
    function adicionarItem() {
        var div = document.createElement('div');
        div.className = 'd-flex gap-2 mb-2';
        div.innerHTML = `
            <input class="form-control" name="CodigosBarras[${contador}]" placeholder="Código de Barras*" required />
            <input class="form-control" name="Tamanhos[${contador}]" placeholder="Tamanho* (ex: 10, 12...)" required />
            <input class="form-control" name="Quantidades[${contador}]" type="number" min="1" placeholder="Qtd*" required />
            <button type="button" class="btn btn-danger" onclick="removerItem(this)">✕</button>
        `;
        document.getElementById('itens').appendChild(div);
        contador++;
    }
        function removerItem(btn) {
            btn.closest('div').remove();
    }
</script>