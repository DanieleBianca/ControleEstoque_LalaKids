<h1 class="mb-3">Movimentar Estoque</h1>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">
        @TempData["Erro"]
        </div>
}

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">
        @TempData["Sucesso"]
        </div>
}

<form action="/produto/movimentar" method="POST">

    <div class="mb-3">
        <label>Tipo de Movimentação</label>
        <div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="tipo" value="entrada" id="entrada" checked />
                <label class="form-check-label" for="entrada">Entrada</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="tipo" value="saida" id="saida" />
                <label class="form-check-label" for="saida">Saída</label>
            </div>
        </div>
    </div>

    <h5 class="mt-3">Produtos</h5>
    <div id="itens">
        <div class="d-flex gap-2 mb-2">
            <input class="form-control" name="CodigosBarras[0]" placeholder="Código de Barras" />
            <input class="form-control" name="Tamanhos[0]" placeholder="Tamanho (ex: P, 36...)" />
            <input class="form-control" name="Quantidades[0]" type="number" min="1" placeholder="Quantidade" />
        </div>
    </div>

    <button type="button" class="btn btn-secondary mb-3" onclick="adicionarItem()">+ Adicionar produto</button>

    <br />
    <button class="btn btn-primary mt-2">Confirmar</button>
    <a href="/produto/index" class="btn btn-secondary mt-2">Cancelar</a>

</form>

<script>
    var contador = 1;
    function adicionarItem() {
        var div = document.createElement('div');
        div.className = 'd-flex gap-2 mb-2';
        div.innerHTML = `
            <input class="form-control" name="CodigosBarras[${contador}]" placeholder="Código de Barras" />
            <input class="form-control" name="Tamanhos[${contador}]" placeholder="Tamanho (ex: P, 36...)" />
            <input class="form-control" name="Quantidades[${contador}]" type="number" min="1" placeholder="Quantidade" />
        `;
        document.getElementById('itens').appendChild(div);
        contador++;
    }
</script>