<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; display: flex; min-height: 100vh; }

    .sidebar {
        width: 260px;
        min-height: 100vh;
        background-color: #BDD7E7;
        display: flex;
        flex-direction: column;
        padding: 24px 16px;
        position: fixed;
        top: 0; left: 0;
        box-shadow: 2px 0 8px rgba(0,0,0,0.08);
    }
    .sidebar-logo {
        text-align: center;
        margin-bottom: 32px;
    }
    .sidebar-logo img {
        height: 80px;
        object-fit: contain;
    }
    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }
    .btn-sidebar {
        background-color: white;
        color: #1a1a1a;
        border: none;
        border-radius: 8px;
        padding: 12px 16px;
        font-weight: 600;
        text-align: left;
        text-decoration: none;
        display: block;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }
    .btn-sidebar:hover {
        background-color: #e8f0f5;
        transform: translateX(3px);
        color: #1a1a1a;
    }
    .btn-sidebar.ativo {
        background-color: #2E6A8E;
        color: white;
    }
    .btn-sidebar.ativo:hover { color: white; }
    .sidebar-divider {
        border: none;
        border-top: 1px solid rgba(0,0,0,0.15);
        margin: 16px 0;
    }
    .sidebar-footer {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .btn-sidebar-link {
        background: none;
        border: none;
        padding: 8px 4px;
        text-align: left;
        color: #1a1a1a;
        font-size: 0.95rem;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease;
        font-weight: 500;
    }
    .btn-sidebar-link:hover { color: #2E6A8E; }
    .btn-sair { color: #F24822; }
    .btn-sair:hover { color: #c03518; }

    .main-content {
        margin-left: 260px;
        padding: 32px;
        flex: 1;
        width: calc(100% - 260px);
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .main-titulo {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 32px;
        text-align: center;
        width: 100%;
    }
    .card-form {
        background: white;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        width: 100%;
        max-width: 650px;
    }
    .form-control {
        background-color: #f0f2f5;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 10px 14px;
        color: #1a1a1a;
        width: 100%;
    }
    .form-label { font-weight: 600; margin-bottom: 8px; display: block; color: #1a1a1a; }
    .secao-titulo {
        font-weight: 700;
        font-size: 1rem;
        margin: 24px 0 12px 0;
        color: #1a1a1a;
    }
    /* radio buttons customizados */
    .radio-group {
        display: flex;
        gap: 16px;
        margin-top: 8px;
    }
    .radio-option {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        font-weight: 500;
    }
    .radio-option input { cursor: pointer; accent-color: #2E6A8E; }
    .alerta-erro {
        background-color: #fdecea;
        color: #F24822;
        border: 1px solid #F24822;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 16px;
        font-weight: 600;
        width: 100%;
        max-width: 650px;
    }
    .alerta-sucesso {
        background-color: #e8f5e9;
        color: #14ae5c;
        border: 1px solid #14ae5c;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 16px;
        font-weight: 600;
        width: 100%;
        max-width: 650px;
    }
    .btn-adicionar {
        background-color: #f0f2f5;
        color: #2E6A8E;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 8px 16px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s ease, transform 0.1s ease;
        margin-bottom: 24px;
    }
    .btn-adicionar:hover {
        background-color: #e0e8f0;
        transform: translateY(-1px);
    }
    .btn-confirmar {
        background-color: #2E6A8E;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 32px;
        font-weight: bold;
        transition: background-color 0.2s ease, transform 0.1s ease;
        cursor: pointer;
    }
    .btn-confirmar:hover {
        background-color: #245a7a;
        transform: translateY(-1px);
        color: white;
    }
    .link-cancelar {
        color: #555;
        text-decoration: none;
        font-size: 0.9rem;
        margin-left: 16px;
        transition: color 0.2s ease;
    }
    .link-cancelar:hover {
        color: #1a1a1a;
        text-decoration: underline;
    }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.jpg" alt="Logo" onerror="this.style.display='none'" />
    </div>

    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar ativo">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar">Relatórios</a>
    </nav>

    <hr class="sidebar-divider" />

    <div class="sidebar-footer">
        <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
        <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
    </div>
</div>

<div class="main-content">
    <div class="main-titulo">Movimentar Estoque</div>

    @if (TempData["Erro"] != null)
    {
        <div class="alerta-erro">@TempData["Erro"]</div>
    }

    @if (TempData["Sucesso"] != null)
    {
        <div class="alerta-sucesso">@TempData["Sucesso"]</div>
    }

    <div class="card-form">
        <form action="/produto/movimentar" method="POST">

            <div class="mb-3">
                <label class="form-label">Tipo de Movimentação</label>
                <div class="radio-group">
                    <label class="radio-option">
                        <input type="radio" name="tipo" value="entrada" id="entrada" checked />
                        Entrada
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="tipo" value="saida" id="saida" />
                        Saída
                    </label>
                </div>
            </div>

            <p class="secao-titulo">Produtos</p>
            <div id="itens">
                <div class="d-flex gap-2 mb-2">
                    <input class="form-control" name="CodigosBarras[0]" placeholder="Código de Barras" />
                    <input class="form-control" name="Tamanhos[0]" placeholder="Tamanho (ex: 10, 12...)" />
                    <input class="form-control" name="Quantidades[0]" type="number" min="1" placeholder="Quantidade" />
                </div>
            </div>

            <button type="button" class="btn-adicionar" onclick="adicionarItem()">+ Adicionar produto</button>

            <div>
                <button type="submit" class="btn-confirmar">Confirmar</button>
                <a href="/produto/index" class="link-cancelar">Cancelar</a>
            </div>

        </form>
    </div>
</div>

<script>
    var contador = 1;
    function adicionarItem() {
        var div = document.createElement('div');
        div.className = 'd-flex gap-2 mb-2';
        div.innerHTML = `
            <input class="form-control" name="CodigosBarras[${contador}]" placeholder="Código de Barras" />
            <input class="form-control" name="Tamanhos[${contador}]" placeholder="Tamanho" />
            <input class="form-control" name="Quantidades[${contador}]" type="number" min="1" placeholder="Quantidade" />
        `;
        document.getElementById('itens').appendChild(div);
        contador++;
    }
</script>