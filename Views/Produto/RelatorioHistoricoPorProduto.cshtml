@model List<MovimentacaoItem>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; display: flex; min-height: 100vh; }

    .sidebar {
        width: 260px; min-height: 100vh; background-color: #BDD7E7;
        display: flex; flex-direction: column; padding: 24px 16px;
        position: fixed; top: 0; left: 0;
        box-shadow: 2px 0 8px rgba(0,0,0,0.08);
    }
    .sidebar-logo { text-align: center; margin-bottom: 32px; }
    .sidebar-logo img { height: 80px; object-fit: contain; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .btn-sidebar {
        background-color: white; color: #1a1a1a; border: none;
        border-radius: 8px; padding: 12px 16px; font-weight: 600;
        text-align: left; text-decoration: none; display: block;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }
    .btn-sidebar:hover { background-color: #e8f0f5; transform: translateX(3px); color: #1a1a1a; }
    .btn-sidebar.ativo { background-color: #2E6A8E; color: white; }
    .sidebar-divider { border: none; border-top: 1px solid rgba(0,0,0,0.15); margin: 16px 0; }
    .sidebar-footer { display: flex; flex-direction: column; gap: 10px; }
    .btn-sidebar-link {
        background: none; border: none; padding: 8px 4px;
        text-align: left; color: #1a1a1a; font-size: 0.95rem;
        text-decoration: none; display: block;
        transition: color 0.2s ease; font-weight: 500;
    }
    .btn-sidebar-link:hover { color: #2E6A8E; }
    .btn-sair { color: #F24822; }
    .btn-sair:hover { color: #c03518; }

    .main-content { margin-left: 260px; padding: 48px; flex: 1; width: calc(100% - 260px); }
    .page-header {
        display: flex; align-items: center;
        justify-content: space-between; margin-bottom: 8px;
    }
    .main-titulo { font-size: 1.8rem; font-weight: 700; }
    .main-subtitulo { color: #888; font-size: 0.9rem; margin-bottom: 32px; }
    .btn-voltar {
        background-color: white; color: #1a1a1a;
        border: 1px solid #ebebeb; border-radius: 8px;
        padding: 9px 20px; font-weight: 600; font-size: 0.85rem;
        text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
        transition: background-color 0.2s ease, border-color 0.2s ease;
    }
    .btn-voltar:hover { background-color: #f0f0ee; border-color: #ccc; color: #1a1a1a; }

    .card-tabela {
        background: white; border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06); overflow: hidden;
    }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background-color: #f4f8fb; }
    th {
        padding: 13px 28px; font-size: 0.75rem; font-weight: 700;
        color: #888; text-transform: uppercase; letter-spacing: 0.06em;
        text-align: left; border-bottom: 1px solid #f0f0f0;
    }
    td { padding: 14px 28px; font-size: 0.9rem; border-bottom: 1px solid #f8f8f6; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background-color: #f9fbfd; }

    .badge-tipo {
        display: inline-block; border-radius: 6px;
        padding: 4px 12px; font-size: 0.78rem;
        font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .badge-entrada { background-color: #e8f5e9; color: #14ae5c; }
    .badge-saida { background-color: #fdecea; color: #F24822; }

    .alerta-info {
        background-color: #f0f6fa; color: #2E6A8E;
        border: 1px solid #bdd7e7; border-radius: 8px;
        padding: 16px 20px; font-size: 0.9rem;
    }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.jpg" alt="Logo" onerror="this.style.display='none'" />
    </div>
    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar ativo">Relatórios</a>
    </nav>
    <hr class="sidebar-divider" />
    <div class="sidebar-footer">
        <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
        <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
    </div>
</div>

<div class="main-content">
    <div class="page-header">
        <div>
            <div class="main-titulo">@ViewBag.Produto.Nome</div>
            <div class="main-subtitulo">Histórico de movimentações — @ViewBag.Produto.CodigoBarras</div>
        </div>
        <a href="/produto/relatorioHistoricoPorProduto" class="btn-voltar">Voltar</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alerta-info">Nenhuma movimentação registrada para este produto.</div>
    }
    else
    {
        <div class="card-tabela">
            <table>
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Tamanho</th>
                        <th>Quantidade</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var mov = ((List<Movimentacao>)ViewBag.Movimentacoes).FirstOrDefault(m => m.Id == item.IdMovimentacao);
                        <tr>
                            <td>
                                <span class="badge-tipo @(mov?.Tipo == "entrada" ? "badge-entrada" : "badge-saida")">
                                    @(mov?.Tipo == "entrada" ? "Entrada" : "Saída")
                                </span>
                            </td>
                            <td>@item.Tamanho</td>
                            <td>@item.Quantidade</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>