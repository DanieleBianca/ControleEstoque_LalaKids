<h1 class="mb-3">Novo Produto</h1>

<form action="/produto/create" method="POST">
    <div class="mb-2">
        <label>Código de Barras</label>
        <input class="form-control" name="CodigoBarras" />
    </div>
    <div class="mb-2">
        <label>Nome</label>
        <input class="form-control" name="Nome" />
    </div>
    <div class="mb-2">
        <label>Descrição</label>
        <input class="form-control" name="Descricao" />
    </div>
    <div class="mb-2">
        <label>Valor de Compra</label>
        <input class="form-control" name="ValorCompra" />
    </div>
    <div class="mb-2">
        <label>Valor de Revenda</label>
        <input class="form-control" name="ValorRevenda" />
    </div>

    <!-- seção de tamanhos -->
    <h5 class="mt-3">Tamanhos e Quantidades</h5>
    <div id="tamanhos">
        <div class="d-flex gap-2 mb-2">
            <input class="form-control" name="Tamanhos[0]" placeholder="Tamanho (ex: P, 36...)" />
            <input class="form-control" name="Quantidades[0]" type="number" min="0" placeholder="Quantidade" />
        </div>
    </div>

    <!-- botão para adicionar mais tamanhos dinamicamente -->
    <button type="button" class="btn btn-secondary mb-3" onclick="adicionarTamanho()">+ Adicionar tamanho</button>

    <br/>
    <button class="btn btn-success mt-2">Salvar</button>
    <a href="/produto/index" class="btn btn-secondary mt-2">Cancelar</a>
</form>

<!-- script para adicionar campos de tamanho dinamicamente -->
<script>
    var contador = 1;
    function adicionarTamanho() {
        var div = document.createElement('div');
        div.className = 'd-flex gap-2 mb-2';
        div.innerHTML = `
            <input class="form-control" name="Tamanhos[${contador}]" placeholder="Tamanho (ex: P, 36...)" />
            <input class="form-control" name="Quantidades[${contador}]" type="number" min="0" placeholder="Quantidade" />
        `;
        document.getElementById('tamanhos').appendChild(div);
        contador++;
    }
</script>