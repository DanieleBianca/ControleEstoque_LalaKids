<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; display: flex; min-height: 100vh; }

    .sidebar {
        width: 220px;
        min-height: 100vh;
        background-color: #BDD7E7;
        display: flex;
        flex-direction: column;
        padding: 28px 16px;
        position: fixed;
        top: 0; left: 0;
        border-right: 1px solid rgba(0,0,0,0.06);
    }
    .sidebar-logo { text-align: center; margin-bottom: 40px; }
    .sidebar-logo img { width: 140px; height: auto; object-fit: contain; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .btn-sidebar {
        background-color: transparent;
        color: #1a1a1a; /* azul escuro legível sobre o fundo azul */
        border: none;
        border-radius: 8px;
        padding: 10px 14px;
        font-weight: 500;
        font-size: 0.9rem;
        text-align: left;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
    }
    .btn-sidebar:hover {
        background-color: rgba(255,255,255,0.35); /* branco translúcido no hover */
        color: #1a1a1a;
    }
    .btn-sidebar.ativo {
        background-color: rgba(255,255,255,0.5); /* mais opaco no ativo */
        color: #1a3a50;
        font-weight: 700;
    }
    .btn-sidebar.ativo:hover { color: #1a3a50; }

    .sidebar-divider { border: none; border-top: 1px solid rgba(0,0,0,0.1); margin: 20px 0; }
    .sidebar-footer { display: flex; flex-direction: column; gap: 2px; }
    .btn-sidebar-link {
        background: none;
        border: none;
        padding: 10px 14px;
        text-align: left;
        color: #2a4a5e;
        font-size: 0.9rem;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
        font-weight: 500;
        border-radius: 8px;
    }
    .btn-sidebar-link:hover { background-color: rgba(255,255,255,0.35); color: #1a1a1a; }
    .btn-sair { color: #a83210 !important; }
    .btn-sair:hover { background-color: rgba(242,72,34,0.12) !important; color: #a83210 !important; }

    .main-content {
        margin-left: 260px;
        padding: 48px;
        flex: 1;
        width: calc(100% - 260px);
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .main-titulo { font-size: 1.8rem; font-weight: 700; margin-bottom: 4px; text-align: center; width: 100%; }
    .main-subtitulo { color: #888; font-size: 0.9rem; font-weight: 400; text-align: center; margin-bottom: 32px; width: 100%; }

    .card-form {
        background: white;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        width: 100%;
        max-width: 600px;
    }
    .form-control {
        background-color: #f8f8f6;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 10px 14px;
        color: #1a1a1a;
        width: 100%;
        transition: border-color 0.2s ease;
    }
    .form-control:focus { outline: none; border-color: #2E6A8E; background-color: white; }
    .form-label { font-weight: 600; font-size: 0.85rem; color: #666; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.04em; }
    .secao-titulo {
        font-weight: 700;
        font-size: 0.85rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin: 28px 0 12px 0;
        padding-bottom: 8px;
        border-bottom: 1px solid #f0f0f0;
    }
    .btn-adicionar {
        background-color: transparent;
        color: #2E6A8E;
        border: 1px dashed #2E6A8E;
        border-radius: 8px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: background-color 0.2s ease;
        margin-bottom: 28px;
        width: 100%;
    }
    .btn-adicionar:hover { background-color: #f0f6fa; }
    .btn-remover-tamanho {
        background-color: transparent;
        color: #F24822;
        border: 1px solid #F24822;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
        transition: all 0.2s ease;
    }
    .btn-remover-tamanho:hover { background-color: #F24822; color: white; }
    .acoes { display: flex; align-items: center; gap: 16px; margin-top: 8px; }
    .btn-salvar {
        background-color: #2E6A8E;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 36px;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        transition: background-color 0.2s ease, transform 0.1s ease;
        cursor: pointer;
    }
    .btn-salvar:hover { background-color: #245a7a; transform: translateY(-1px); color: white; }
    .link-cancelar {
        color: #aaa;
        text-decoration: none;
        font-size: 0.88rem;
        transition: color 0.2s ease;
    }
    .link-cancelar:hover { color: #555; text-decoration: underline; }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.png" alt="Logo" onerror="this.style.display='none'" />
    </div>
    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar ativo">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar">Relatórios</a>
    </nav>
    <hr class="sidebar-divider" />
    <div class="sidebar-footer">
        <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
        <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
    </div>
</div>

<div class="main-content">
    <div class="main-titulo">Editar Produto</div>
    <div class="main-subtitulo">Atualize os dados do produto</div>

    @if (TempData["Erro"] != null)
    {
        <div style="background:#fdecea; color:#F24822; border:1px solid #F24822; border-radius:8px; padding:12px 16px; margin-bottom:16px; font-weight:600; width:100%; max-width:600px;">
            @TempData["Erro"]
        </div>
    }

    <div class="card-form">
        <form action="/produto/update" method="POST">
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">Código de Barras*</label>
                <input class="form-control" name="CodigoBarras" value="@Model.CodigoBarras" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Nome*</label>
                <input class="form-control" name="Nome" value="@Model.Nome" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Marca*</label>
                <input class="form-control" name="Marca" value="@Model.Marca" required/>
            </div>
            <div class="mb-3">
                <label class="form-label">Valor de Compra*</label>
                <input class="form-control" name="ValorCompra" value="@Model.ValorCompra" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Valor de Revenda*</label>
                <input class="form-control" name="ValorRevenda" value="@Model.ValorRevenda" required />
            </div>

            <p class="secao-titulo">Tamanhos e Quantidades</p>
            <div id="tamanhos">
                @foreach (var pt in (List<ProdutoTamanho>)ViewBag.Tamanhos)
                {
                    <div class="d-flex gap-2 mb-2 align-items-center">
                        <input type="hidden" name="TamanhoIds[]" value="@pt.Id" />
                        <input class="form-control" name="Tamanhos[]" value="@pt.Tamanho" placeholder="Tamanho" />
                        <input class="form-control" name="Quantidades[]" value="@pt.Quantidade" type="number" placeholder="Quantidade" />
                        <a href="/produto/deletartamanho/@pt.Id" class="btn-remover-tamanho">Remover</a>
                    </div>
                }
            </div>

            <button type="button" class="btn-adicionar" onclick="adicionarTamanho()">+ Adicionar tamanho</button>

            <div class="acoes">
                <button type="submit" class="btn-salvar">Salvar</button>
                <a href="/produto/index" class="link-cancelar">Cancelar</a>
            </div>
        </form>
    </div>
</div>

<script>
    function adicionarTamanho() {
        var div = document.createElement('div');
        div.className = 'd-flex gap-2 mb-2 align-items-center';
        div.innerHTML = `
            <input type="hidden" name="TamanhoIds[]" value="" />
            <input class="form-control" name="Tamanhos[]" placeholder="Tamanho (ex: 10, 12...)" />
            <input class="form-control" name="Quantidades[]" type="number" placeholder="Quantidade" />
        `;
        document.getElementById('tamanhos').appendChild(div);
    }
</script>