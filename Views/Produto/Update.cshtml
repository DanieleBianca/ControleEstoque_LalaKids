<h1 class="mb-3">Editar Produto</h1>

<form action="/produto/update" method="POST">
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="mb-2">
        <label>Código de Barras</label>
        <input class="form-control" name="CodigoBarras" value="@Model.CodigoBarras" />
    </div>
    <div class="mb-2">
        <label>Nome</label>
        <input class="form-control" name="Nome" value="@Model.Nome" />
    </div>
    <div class="mb-2">
        <label>Descrição</label>
        <input class="form-control" name="Descricao" value="@Model.Descricao" />
    </div>
    <div class="mb-2">
        <label>Valor de Compra</label>
        <input class="form-control" name="ValorCompra" value="@Model.ValorCompra" />
    </div>
    <div class="mb-2">
        <label>Valor de Revenda</label>
        <input class="form-control" name="ValorRevenda" value="@Model.ValorRevenda" />
    </div>

    <!-- tamanhos já cadastrados -->
    <h5 class="mt-3">Tamanhos e Quantidades</h5>
    <div id="tamanhos">
        @foreach (var pt in (List<ProdutoTamanho>)ViewBag.Tamanhos)
        {
            <div class="d-flex gap-2 mb-2">
                <!-- id oculto do produtoTamanho para atualizar o correto -->
                <input type="hidden" name="TamanhoIds[]" value="@pt.Id" />
                <input class="form-control" name="Tamanhos[]" value="@pt.Tamanho" placeholder="Tamanho" />
                <input class="form-control" name="Quantidades[]" value="@pt.Quantidade" type="number" placeholder="Quantidade" />
            </div>
        }
    </div>

    <button type="button" class="btn btn-secondary mb-3" onclick="adicionarTamanho()">+ Adicionar tamanho</button>

    <br/>
    <button class="btn btn-primary mt-2">Salvar</button>
    <a href="/produto/index" class="btn btn-secondary mt-2">Cancelar</a>
</form>

<script>
    function adicionarTamanho() {
        var div = document.createElement('div');
        div.className = 'd-flex gap-2 mb-2';
        div.innerHTML = `
            <input type="hidden" name="TamanhoIds[]" value="" />
            <input class="form-control" name="Tamanhos[]" placeholder="Tamanho (ex: P, 36...)" />
            <input class="form-control" name="Quantidades[]" type="number" placeholder="Quantidade" />
        `;
        document.getElementById('tamanhos').appendChild(div);
    }
</script>