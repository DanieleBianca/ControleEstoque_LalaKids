@model List<Movimentacao>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; display: flex; min-height: 100vh; }

    .sidebar {
        width: 220px;
        min-height: 100vh;
        background-color: #BDD7E7;
        display: flex;
        flex-direction: column;
        padding: 28px 16px;
        position: fixed;
        top: 0; left: 0;
        border-right: 1px solid rgba(0,0,0,0.06);
    }
    .sidebar-logo { text-align: center; margin-bottom: 40px; }
    .sidebar-logo img { width: 140px; height: auto; object-fit: contain; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .btn-sidebar {
        background-color: transparent;
        color: #1a1a1a; /* azul escuro legível sobre o fundo azul */
        border: none;
        border-radius: 8px;
        padding: 10px 14px;
        font-weight: 500;
        font-size: 0.9rem;
        text-align: left;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
    }
    .btn-sidebar:hover {
        background-color: rgba(255,255,255,0.35); /* branco translúcido no hover */
        color: #1a1a1a;
    }
    .btn-sidebar.ativo {
        background-color: rgba(255,255,255,0.5); /* mais opaco no ativo */
        color: #1a3a50;
        font-weight: 700;
    }
    .btn-sidebar.ativo:hover { color: #1a3a50; }

    .sidebar-divider { border: none; border-top: 1px solid rgba(0,0,0,0.1); margin: 20px 0; }
    .sidebar-footer { display: flex; flex-direction: column; gap: 2px; }
    .btn-sidebar-link {
        background: none;
        border: none;
        padding: 10px 14px;
        text-align: left;
        color: #2a4a5e;
        font-size: 0.9rem;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
        font-weight: 500;
        border-radius: 8px;
    }
    .btn-sidebar-link:hover { background-color: rgba(255,255,255,0.35); color: #1a1a1a; }
    .btn-sair { color: #a83210 !important; }
    .btn-sair:hover { background-color: rgba(242,72,34,0.12) !important; color: #a83210 !important; }

    .main-content {
        margin-left: 260px;
        padding: 48px;
        flex: 1;
        width: calc(100% - 260px);
    }
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
    }
    .main-titulo { font-size: 1.8rem; font-weight: 700; }
    .main-subtitulo { color: #888; font-size: 0.9rem; margin-bottom: 32px; }
    .btn-voltar {
        background-color: white;
        color: #1a1a1a;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 9px 20px;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
        transition: background-color 0.2s ease, border-color 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .btn-voltar:hover { background-color: #f0f0ee; border-color: #ccc; color: #1a1a1a; }

    /* cards de movimentação */
    .movimentacao-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        margin-bottom: 16px;
        overflow: hidden;
        transition: box-shadow 0.2s ease;
    }
    .movimentacao-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
    .card-topo {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 24px;
        border-bottom: 1px solid #f5f5f5;
    }
    .card-topo-info { display: flex; align-items: center; gap: 12px; }
    .badge-tipo {
        display: inline-block;
        border-radius: 6px;
        padding: 4px 12px;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .badge-entrada { background-color: #e8f5e9; color: #14ae5c; }
    .badge-saida { background-color: #fdecea; color: #F24822; }
    .card-data { font-size: 0.85rem; color: #888; }
    .card-usuario { font-size: 0.85rem; color: #aaa; }
    .btn-desfazer {
        background-color: transparent;
        color: #F24822;
        border: 1px solid #F24822;
        border-radius: 6px;
        padding: 6px 14px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
        white-space: nowrap;
    }
    .btn-desfazer:hover { background-color: #F24822; color: white; }
    .card-corpo { padding: 0; }
    table { width: 100%; border-collapse: collapse; }
    th {
        padding: 11px 24px;
        font-size: 0.75rem;
        font-weight: 700;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        text-align: left;
        background-color: #fafafa;
        border-bottom: 1px solid #f0f0f0;
    }
    td { padding: 12px 24px; font-size: 0.9rem; border-bottom: 1px solid #f8f8f6; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background-color: #fafafa; }

    .alerta-info {
        background-color: #f0f6fa;
        color: #2E6A8E;
        border: 1px solid #bdd7e7;
        border-radius: 8px;
        padding: 16px 20px;
        font-size: 0.9rem;
    }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.jpg" alt="Logo" onerror="this.style.display='none'" />
    </div>
    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar ativo">Relatórios</a>
    </nav>
    <hr class="sidebar-divider" />
    <div class="sidebar-footer">
        <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
        <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
    </div>
</div>

<div class="main-content">

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">@TempData["Erro"]</div>
    }
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }

    <div class="page-header">
        <div>
            <div class="main-titulo">Histórico de Movimentações</div>
            <div class="main-subtitulo">Todas as entradas e saídas registradas</div>
        </div>
        <a href="/produto/relatorios" class="btn-voltar">Voltar</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alerta-info">Nenhuma movimentação registrada ainda.</div>
    }
    else
    {
        @foreach (var m in Model)
        {
            var usuario = ((List<Usuario>)ViewBag.Usuarios)
                .FirstOrDefault(u => u.Id == m.IdUsuario);

            var itens = ((List<MovimentacaoItem>)ViewBag.Itens)
                .Where(i => i.IdMovimentacao == m.Id)
                .ToList();

            <div class="movimentacao-card">
                <div class="card-topo">
                    <div class="card-topo-info">
                        <span class="badge-tipo @(m.Tipo == "entrada" ? "badge-entrada" : "badge-saida")">
                            @(m.Tipo == "entrada" ? "Entrada" : "Saída")
                        </span>
                        <span class="card-data">@m.Data.ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="card-usuario">@(usuario?.Nome ?? "Usuário desconhecido")</span>
                    </div>
                    <a href="/produto/desfazermovimentacao/@m.Id" class="btn-desfazer"
                       onclick="return confirm('Deseja desfazer esta movimentação?')">
                        Desfazer
                    </a>
                </div>
                <div class="card-corpo">
                    <table>
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th>Tamanho</th>
                                <th>Quantidade</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in itens)
                            {
                                var produto = ((List<Produto>)ViewBag.Produtos)
                                    .FirstOrDefault(p => p.Id == item.IdProduto);
                                <tr>
                                    <td>@(produto?.Nome ?? "Produto desconhecido")</td>
                                    <td>@item.Tamanho</td>
                                    <td>@item.Quantidade</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>