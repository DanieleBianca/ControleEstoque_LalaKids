<h1 class="mb-3">Produtos</h1>

<a href="/produto/create" class="btn btn-primary mb-3">Novo Produto</a>
<a href="/produto/movimentar" class="btn btn-success mb-3">Movimentar Estoque</a>
<a href="/Usuario/Index" class="btn btn-danger mb-3">Gerenciar Usuários</a>

<table class="table table-bordered">
    <tr>
        <th>Código de Barras</th>
        <th>Nome</th>
        <th>Descrição</th>
        <th>Valor de Compra</th>
        <th>Valor de Revenda</th>
        <th>Ações</th>
    </tr>
    @foreach (var p in Model)
    {
        @*aba de tamanhos*@
        var tamanhosDoProduto = ((List<ProdutoTamanho>)ViewBag.ProdutoTamanhos)
            .Where(pt => pt.IdProduto == p.Id).ToList();

        var conteudoPopover = tamanhosDoProduto.Any()
            ? string.Join("<br/>", tamanhosDoProduto.Select(pt => $"{pt.Tamanho}: {pt.Quantidade} unidades"))
            : "Sem tamanhos cadastrados"; //default

        <tr>
            <td>@p.CodigoBarras</td>
            <td>
                <!-- clica no nome para expandir os tamanhos -->
                <span
                    data-bs-toggle="popover"
                    data-bs-trigger="hover focus"
                    data-bs-placement="right"
                    data-bs-html="true"
                    data-bs-title="Tamanhos disponíveis"
                    data-bs-content="@conteudoPopover"
                    style="cursor:pointer; text-decoration: underline;">
                    @p.Nome
                </span>
            </td>
            <td>@p.Descricao</td>
            <td>@p.ValorCompra</td>
            <td>@p.ValorRevenda</td>
            <td>
                <a href="/produto/update/@p.Id" class="btn btn-warning btn-sm">Editar</a>
                <a href="/produto/delete/@p.Id" class="btn btn-danger btn-sm">Excluir</a>
            </td>
        </tr>
        @* linha colapsável com os tamanhos*@
       
    }
</table>

<a href="/Usuario/Logout" class="btn btn-secondary"
   style="position: fixed; bottom: 20px; left: 20px;">
    Sair
</a>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => {
        new bootstrap.Popover(el);
    });
</script>
