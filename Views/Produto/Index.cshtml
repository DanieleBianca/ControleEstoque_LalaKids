<!-- botão para ir para a tela de cadastro de novo produto e movimentar estoque -->
<h1 class="mb-3">Produtos</h1>

<a href="/produto/create" class="btn btn-primary mb-3">Novo Produto</a>
<a href="/produto/movimentar" class="btn btn-success mb-3">Movimentar Estoque</a>
<a href="/Usuario/Index" class="btn btn-danger mb-3">Gerenciar Usuários</a>

<table class="table table-bordered">
    <tr>
        <th>Código de Barras</th>
        <th>Nome</th>
        <th>Descrição</th>
        <th>Tamanho</th>
        <th>Valor de Compra</th>
        <th>Valor de Revenda</th>
        <th>Quantidade</th>
        <th>Ações</th>
    </tr>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.CodigoBarras</td>
            <td>@p.Nome</td>
            <td>@p.Descricao</td>
            <td>@p.Tamanho</td>
            <td>@p.ValorCompra</td>
            <td>@p.ValorRevenda</td>
            <td>@p.Quantidade</td>
            <td>
                <a href="/produto/update/@p.Id" class="btn btn-warning btn-sm">Editar</a>
                <a href="/produto/delete/@p.Id" class="btn btn-danger btn-sm">Excluir</a>
            </td>
        </tr>
    }
</table>

<!-- botão sair fixado no canto inferior esquerdo -->
<a href="/Usuario/Logout" class="btn btn-secondary"
   style="position: fixed; bottom: 20px; left: 20px;">
    Sair
</a>
