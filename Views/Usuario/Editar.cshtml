@model Usuario

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }

    body {
        background-color: #f8f8f6;
        margin: 0;
        padding: 0;
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: 260px;
        min-height: 100vh;
        background-color: #BDD7E7;
        display: flex;
        flex-direction: column;
        padding: 24px 16px;
        position: fixed;
        top: 0;
        left: 0;
        box-shadow: 2px 0 8px rgba(0,0,0,0.08);
    }

    .sidebar-logo {
        text-align: center;
        margin-bottom: 32px;
    }

    .sidebar-logo img {
        height: 80px;
        object-fit: contain;
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }

    .btn-sidebar {
        background-color: white;
        color: #1a1a1a;
        border: none;
        border-radius: 8px;
        padding: 12px 16px;
        font-weight: 600;
        text-align: left;
        text-decoration: none;
        display: block;
    }

    .sidebar-divider {
        border: none;
        border-top: 1px solid rgba(0,0,0,0.15);
        margin: 16px 0;
    }

    .sidebar-footer {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .btn-sidebar-link {
        background: none;
        border: none;
        padding: 8px 4px;
        text-align: left;
        color: #1a1a1a;
        font-size: 0.95rem;
        text-decoration: none;
        font-weight: 500;
    }

    .btn-sair {
        color: #F24822;
    }

    .main-content {
        margin-left: 260px;
        padding: 48px;
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .main-titulo {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .main-subtitulo {
        color: #888;
        font-size: 0.9rem;
        margin-bottom: 32px;
    }

    .card-form {
        background: white;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        width: 100%;
        max-width: 700px;
    }

    .campo {
        display: flex;
        flex-direction: column;
        margin-bottom: 20px;
    }

    .campo label {
        margin-bottom: 8px;
        font-weight: 600;
    }

    .campo input {
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 0.95rem;
    }

    .acoes {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 24px;
    }

    .btn-confirmar {
        background-color: #2E6A8E;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 36px;
        font-weight: 700;
        cursor: pointer;
    }

    .link-cancelar {
        color: #888;
        text-decoration: none;
    }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.jpg" alt="Logo" />
    </div>

    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar">Relatórios</a>
    </nav>

    <hr class="sidebar-divider" />

    <div class="sidebar-footer">
        <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
        <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
    </div>
</div>

<div class="main-content">

    <div class="main-titulo">Editar Usuário</div>
    <div class="main-subtitulo">Atualize as informações do usuário</div>

    <div class="card-form">

        <form method="post" action="/Usuario/Editar">

            <input type="hidden" asp-for="Id" />

            <div class="campo">
                <label>Nome</label>
                <input asp-for="Nome" />
            </div>

            <div class="campo">
                <label>Login</label>
                <input asp-for="Login" />
            </div>

            <div class="campo">
                <label>Senha</label>
                <input asp-for="Senha" />
            </div>

            <div class="acoes">
                <button type="submit" class="btn-confirmar">
                    Salvar Alterações
                </button>

                <a href="/Usuario/Index" class="link-cancelar">
                    Cancelar
                </a>
            </div>

        </form>

    </div>
</div>