<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; }

    .header-azul {
        background-color: #BDD7E7;
        width: 100%;
        padding: 32px 0;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .header-azul img { height: 80px; object-fit: contain; }

    .titulo-pagina {
        text-align: center;
        font-weight: 700;
        font-size: 1.8rem;
        margin: 40px 0 4px 0;
    }
    .subtitulo-pagina {
        text-align: center;
        color: #888;
        font-size: 0.9rem;
        font-weight: 400;
        margin-bottom: 32px;
    }

    .card-cadastro {
        max-width: 500px;
        margin: 0 auto 50px auto;
        background: white;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .alerta-erro {
        background-color: #fdecea;
        color: #F24822;
        border: 1px solid #F24822;
        border-radius: 8px;
        padding: 12px 16px;
        margin: 0 auto 16px auto;
        max-width: 500px;
        font-weight: 600;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: #666;
        margin-bottom: 6px;
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .form-control {
        background-color: #f8f8f6;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 10px 14px;
        color: #1a1a1a;
        width: 100%;
        transition: border-color 0.2s ease;
    }
    .form-control:focus { outline: none; border-color: #2E6A8E; background-color: white; }

    .btn-olho {
        background: #f8f8f6;
        border: 1px solid #ebebeb;
        border-left: none;
        border-radius: 0 8px 8px 0;
        color: #888;
        padding: 0 14px;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }
    .btn-olho:hover { background-color: #ebebeb; }

    .btn-cadastrar {
        background-color: #2E6A8E;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 36px;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        display: block;
        width: 100%;
        cursor: pointer;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }
    .btn-cadastrar:hover { background-color: #245a7a; color: white; transform: translateY(-1px); }

    .link-cancelar {
        display: block;
        text-align: center;
        margin-top: 16px;
        color: #aaa;
        text-decoration: none;
        font-size: 0.88rem;
        transition: color 0.2s ease;
    }
    .link-cancelar:hover { color: #555; text-decoration: underline; }
</style>

<div class="header-azul">
    <img src="/images/logo.jpg" alt="Logo LalaKids" onerror="this.style.display='none'" />
</div>

<h2 class="titulo-pagina">Cadastrar novo usuário</h2>
<p class="subtitulo-pagina">Preencha os dados para criar o acesso</p>

@if (TempData["Erro"] != null)
{
    <div class="alerta-erro">@TempData["Erro"]</div>
}

<div class="card-cadastro">
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Nome</label>
            <input class="form-control" type="text" name="Nome" required placeholder="Digite o nome completo" />
        </div>
        <div class="mb-3">
            <label class="form-label">Login</label>
            <input class="form-control" type="text" name="Login" required placeholder="" />
        </div>
        <div class="mb-3">
            <label class="form-label">Senha</label>
            <div class="input-group">
                <input class="form-control" type="password" name="Senha" id="campoSenha"
                       required placeholder="" style="border-radius: 8px 0 0 8px;" />
                <button class="btn-olho" type="button" onclick="alternarSenha()">👁</button>
            </div>
        </div>
        <button class="btn-cadastrar mt-2">CADASTRAR</button>
        <a href="/usuario/login" class="link-cancelar">Voltar para o login</a>
    </form>
</div>

<script>
    function alternarSenha() {
        var campo = document.getElementById('campoSenha');
        campo.type = campo.type === 'password' ? 'text' : 'password';
    }
</script>