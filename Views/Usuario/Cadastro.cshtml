<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; }
    .header-azul {
        background-color: #BDD7E7;
        width: 100%;
        padding: 32px 0;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .titulo-pagina {
        text-align: center;
        font-weight: 700;
        font-size: 1.8rem;
        color: #1a1a1a;
        margin: 40px 0 20px 0;
    }
    .card-cadastro {
        max-width: 500px;
        margin: 0 auto 50px auto;
        background: white;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    }
    .form-control {
        background-color: #f0f2f5;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 12px;
        color: #1a1a1a;
    }
    .form-label { font-weight: 600; color: #1a1a1a; margin-bottom: 4px; }
    .btn-cadastrar {
        background-color: #2E6A8E;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 50px;
        font-weight: bold;
        letter-spacing: 1px;
        display: block;
        margin: 0 auto;
        width: 100%;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }
    .btn-cadastrar:hover {
        background-color: #245a7a;
        color: white;
        transform: translateY(-1px);
    }
    .btn-olho {
        background: #f0f2f5;
        border: 1px solid #e0e0e0;
        border-left: none;
        border-radius: 0 8px 8px 0;
        color: #555;
        padding: 0 12px;
        transition: background-color 0.2s ease;
    }
    .btn-olho:hover { background-color: #e0e0e0; }
    .link-voltar {
        display: block;
        text-align: center;
        margin-top: 16px;
        color: #2E6A8E;
        text-decoration: none;
        font-size: 0.9rem;
        transition: text-decoration 0.1s ease;
    }
    .link-voltar:hover {
        text-decoration: underline;
        color: #2E6A8E;
    }
</style>

<div class="header-azul">
    <img src="/images/logo.jpg" alt="Logo LalaKids" height="100" onerror="this.style.display='none'" />
</div>

<h2 class="titulo-pagina">Cadastrar novo usuário</h2>

<div class="card-cadastro">
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Nome</label>
            <input class="form-control" type="text" name="Nome" required placeholder="Digite o nome completo" />
        </div>
        <div class="mb-3">
            <label class="form-label">Login</label>
            <input class="form-control" type="text" name="Login" required placeholder="Digite o login" />
        </div>
        <div class="mb-3">
            <label class="form-label">Senha</label>
            <div class="input-group">
                <input class="form-control" type="password" name="Senha" id="campoSenha"
                       required placeholder="Digite a senha" style="border-radius: 8px 0 0 8px;" />
                <button class="btn-olho" type="button" onclick="alternarSenha()">👁</button>
            </div>
        </div>
        <button class="btn-cadastrar mt-2">CADASTRAR</button>
        <a href="/usuario/login" class="link-voltar">Voltar para o login</a>
    </form>
</div>

<script>
    function alternarSenha() {
        var campo = document.getElementById('campoSenha');
        campo.type = campo.type === 'password' ? 'text' : 'password';
    }
</script>