@using System.Linq
@model IEnumerable<Usuario>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * {
        font-family: 'Poppins', sans-serif;
        color: #1a1a1a;
    }

    body {
        background-color: #f8f8f6;
        margin: 0;
        padding: 0;
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: 220px;
        min-height: 100vh;
        background-color: #BDD7E7;
        display: flex;
        flex-direction: column;
        padding: 28px 16px;
        position: fixed;
        top: 0; left: 0;
        border-right: 1px solid rgba(0,0,0,0.06);
    }
    .sidebar-logo { text-align: center; margin-bottom: 40px; }
    .sidebar-logo img { width: 140px; height: auto; object-fit: contain; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .btn-sidebar {
        background-color: transparent;
        color: #1a1a1a; /* azul escuro legível sobre o fundo azul */
        border: none;
        border-radius: 8px;
        padding: 10px 14px;
        font-weight: 500;
        font-size: 0.9rem;
        text-align: left;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
    }
    .btn-sidebar:hover {
        background-color: rgba(255,255,255,0.35); /* branco translúcido no hover */
        color: #1a1a1a;
    }
    .btn-sidebar.ativo {
        background-color: rgba(255,255,255,0.5); /* mais opaco no ativo */
        color: #1a3a50;
        font-weight: 700;
    }
    .btn-sidebar.ativo:hover { color: #1a3a50; }

    .sidebar-divider { border: none; border-top: 1px solid rgba(0,0,0,0.1); margin: 20px 0; }
    .sidebar-footer { display: flex; flex-direction: column; gap: 2px; }
    .btn-sidebar-link {
        background: none;
        border: none;
        padding: 10px 14px;
        text-align: left;
        color: #2a4a5e;
        font-size: 0.9rem;
        text-decoration: none;
        display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
        font-weight: 500;
        border-radius: 8px;
    }
    .btn-sidebar-link:hover { background-color: rgba(255,255,255,0.35); color: #1a1a1a; }
    .btn-sair { color: #a83210 !important; }
    .btn-sair:hover { background-color: rgba(242,72,34,0.12) !important; color: #a83210 !important; }

    .main-content {
        margin-left: 260px;
        padding: 48px;
        flex: 1;
        width: calc(100% - 260px);
    }

    .main-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 40px;
        text-align: center;
    }

    .main-titulo {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 4px;
        text-align: center;
    }

    .main-subtitulo {
        color: #888;
        font-size: 0.9rem;
        font-weight: 400;
        text-align: center;
        margin-bottom: 20px;
    }

    .btn-novo {
        background-color: #2E6A8E;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 22px;
        font-weight: 600;
        text-decoration: none;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

    .btn-novo:hover {
        background-color: #245a7a;
        color: white;
        transform: translateY(-1px);
    }

    .tabela-wrapper {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        overflow: hidden;
        max-width: 760px;
        width: 100%;
        margin: 0 auto;
    }

    .table {
        width: 100%;
        margin: 0;
        border-collapse: collapse;
    }

    .table thead tr {
        border-bottom: 1px solid #f0f0f0;
    }

    .table th {
        font-weight: 600;
        font-size: 0.78rem;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 16px 20px;
        text-align: left;
    }

    .table td {
        padding: 16px 20px;
        border-bottom: 1px solid #f5f5f5;
        font-size: 0.92rem;
        vertical-align: middle;
    }

    .table tbody tr {
        transition: background-color 0.15s ease;
    }

    .table tbody tr:hover {
        background-color: #fafafa;
    }

    .usuario-nome {
        font-weight: 500;
    }

    .btn-editar {
        background-color: #14ae5c;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 5px 14px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

    .btn-editar:hover {
        background-color: #0e8a48;
        color: white;
        transform: translateY(-1px);
    }

    .btn-excluir {
        background-color: transparent;
        color: #F24822;
        border: 1px solid #F24822;
        border-radius: 6px;
        padding: 5px 14px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-left: 6px;
        transition: all 0.2s ease;
    }

    .btn-excluir:hover {
        background-color: #F24822;
        color: white;
        transform: translateY(-1px);
    }

    .alerta {
        border-radius: 12px;
        padding: 16px 20px;
        font-size: 0.9rem;
        margin-bottom: 24px;
    }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.jpg" alt="Logo"
             onerror="this.style.display='none'" />
    </div>

    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar">Relatórios</a>
    </nav>

    <hr class="sidebar-divider" />

    <div class="sidebar-footer">
        <a href="/Usuario/Index"
           class="btn-sidebar-link"
           style="color: #2E6A8E; font-weight: 600;">
            Gerenciar Usuários
        </a>

        <a href="/Usuario/Logout"
           class="btn-sidebar-link btn-sair">
            Sair
        </a>
    </div>
</div>

<div class="main-content">
    <div class="main-header">
        <div>
            <div class="main-titulo">Gerenciar Usuários</div>
            <div class="main-subtitulo">
                Edite ou remova os usuários do sistema
            </div>
        </div>
        </a>
    </div>
    @if (!Model.Any())
    {
        <div class="alert alert-info alerta">
            Nenhum usuário cadastrado.
        </div>
    }
    else
    {
        <div class="tabela-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Login</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>
                                <span class="usuario-nome">
                                    @u.Nome
                                </span>
                            </td>
                            <td>
                                @u.Login
                            </td>
                            <td>
                                <a href="/Usuario/Editar/@u.Id"
                                   class="btn-editar">
                                    Editar
                                </a>
                                @if (u.Id != Context.Session.GetString("UsuarioId"))
                                {
                                    <a href="/Usuario/Delete/@u.Id"
                                       class="btn-excluir"
                                       onclick="return confirm('Tem certeza que deseja excluir @u.Nome?')">
                                        Excluir
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>