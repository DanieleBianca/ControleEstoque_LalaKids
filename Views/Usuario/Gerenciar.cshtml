@model IEnumerable<Usuario>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }

    body {
        background-color: #f8f8f6;
        margin: 0;
        padding: 0;
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: 260px;
        min-height: 100vh;
        background-color: #BDD7E7;
        display: flex;
        flex-direction: column;
        padding: 24px 16px;
        position: fixed;
        top: 0;
        left: 0;
        box-shadow: 2px 0 8px rgba(0,0,0,0.08);
    }

    .sidebar-logo {
        text-align: center;
        margin-bottom: 32px;
    }

    .sidebar-logo img {
        height: 80px;
        object-fit: contain;
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }

    .btn-sidebar {
        background-color: white;
        color: #1a1a1a;
        border: none;
        border-radius: 8px;
        padding: 12px 16px;
        font-weight: 600;
        text-align: left;
        text-decoration: none;
        display: block;
        transition: 0.2s;
    }

    .btn-sidebar:hover {
        background-color: #e8f0f5;
        transform: translateX(3px);
    }

    .sidebar-divider {
        border: none;
        border-top: 1px solid rgba(0,0,0,0.15);
        margin: 16px 0;
    }

    .sidebar-footer {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .btn-sidebar-link {
        background: none;
        border: none;
        padding: 8px 4px;
        text-align: left;
        color: #1a1a1a;
        font-size: 0.95rem;
        text-decoration: none;
        display: block;
        transition: 0.2s;
        font-weight: 500;
    }

    .btn-sidebar-link:hover {
        color: #2E6A8E;
    }

    .btn-sair {
        color: #F24822;
    }

    .main-content {
        margin-left: 260px;
        padding: 48px;
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .main-titulo {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .main-subtitulo {
        color: #888;
        font-size: 0.9rem;
        margin-bottom: 32px;
    }

    .card-form {
        background: white;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        width: 100%;
        max-width: 700px;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
    }

    .table th {
        padding: 12px;
        border-bottom: 1px solid #eee;
        text-align: left;
    }

    .table td {
        padding: 12px;
        border-bottom: 1px solid #eee;
    }

    .btn-editar {
        background-color: #14ae5c;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 6px 14px;
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
    }

    .btn-excluir {
        background-color: transparent;
        color: #F24822;
        border: 1px solid #F24822;
        border-radius: 6px;
        padding: 6px 14px;
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        margin-left: 6px;
    }

    .acoes {
        margin-top: 24px;
    }

    .btn-confirmar {
        background-color: #2E6A8E;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 36px;
        font-weight: 700;
        text-decoration: none;
    }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.jpg" alt="Logo" />
    </div>

    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar">Relatórios</a>
    </nav>

    <hr class="sidebar-divider" />

    <div class="sidebar-footer">
        <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
        <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
    </div>
</div>

<div class="main-content">

    <div class="main-titulo">Gerenciar Usuários</div>
    <div class="main-subtitulo">Edite ou remova os usuários do sistema</div>

    <div class="card-form">

        <table class="table">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Login</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Nome</td>
                        <td>@u.Login</td>

                        <td>
                            <a href="/Usuario/Editar/@u.Id" class="btn-editar">
                                Editar
                            </a>

                            @if (u.Id != Context.Session.GetString("UsuarioId"))
                            {
                                <a href="/Usuario/Delete/@u.Id"
                                   class="btn-excluir"
                                   onclick="return confirm('Excluir @u.Nome?')">
                                    Excluir
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="acoes">
            <a href="/Usuario/Cadastro" class="btn-confirmar">
                Novo Usuário
            </a>
        </div>

    </div>
</div>