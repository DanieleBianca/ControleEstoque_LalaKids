<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Poppins', sans-serif; color: #1a1a1a; }
    body { background-color: #f8f8f6; margin: 0; padding: 0; display: flex; min-height: 100vh; }
    .sidebar {
        width: 220px; min-height: 100vh; background-color: #BDD7E7;
        display: flex; flex-direction: column; padding: 28px 16px;
        position: fixed; top: 0; left: 0; border-right: 1px solid rgba(0,0,0,0.06);
    }
    .sidebar-logo { text-align: center; margin-bottom: 40px; }
    .sidebar-logo img { width: 140px; height: auto; object-fit: contain; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .btn-sidebar {
        background-color: transparent; color: #1a1a1a; border: none;
        border-radius: 8px; padding: 10px 14px; font-weight: 500; font-size: 0.9rem;
        text-align: left; text-decoration: none; display: block;
        transition: color 0.2s ease, background-color 0.2s ease;
    }
    .btn-sidebar:hover { background-color: rgba(255,255,255,0.35); color: #1a1a1a; }
    .sidebar-divider { border: none; border-top: 1px solid rgba(0,0,0,0.1); margin: 20px 0; }
    .sidebar-footer { display: flex; flex-direction: column; gap: 2px; }
    .btn-sidebar-link {
        background: none; border: none; padding: 10px 14px; text-align: left;
        color: #2a4a5e; font-size: 0.9rem; text-decoration: none; display: block;
        transition: color 0.2s ease, background-color 0.2s ease; font-weight: 500; border-radius: 8px;
    }
    .btn-sidebar-link:hover { background-color: rgba(255,255,255,0.35); color: #1a1a1a; }
    .btn-sair { color: #a83210 !important; }
    .btn-sair:hover { background-color: rgba(242,72,34,0.12) !important; color: #a83210 !important; }
    .main-content {
        margin-left: 260px; padding: 48px; flex: 1; width: calc(100% - 260px);
        display: flex; flex-direction: column; align-items: center;
    }
    .main-titulo { font-size: 1.8rem; font-weight: 700; margin-bottom: 4px; text-align: center; width: 100%; }
    .main-subtitulo { color: #888; font-size: 0.9rem; font-weight: 400; text-align: center; margin-bottom: 32px; width: 100%; }
    .card-form { background: white; border-radius: 16px; padding: 40px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); width: 100%; max-width: 500px; }
    .campo { margin-bottom: 22px; }
    .form-label { font-weight: 600; font-size: 0.85rem; color: #666; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.04em; }
    .form-control { background-color: #f8f8f6; border: 1px solid #ebebeb; border-radius: 8px; padding: 12px 14px; color: #1a1a1a; width: 100%; font-size: 0.95rem; transition: border-color 0.2s ease; box-sizing: border-box; }
    .form-control:focus { outline: none; border-color: #2E6A8E; background-color: white; }
    .acoes { display: flex; align-items: center; gap: 16px; margin-top: 28px; }
    .btn-confirmar { background-color: #2E6A8E; color: white; border: none; border-radius: 8px; padding: 12px 36px; font-weight: 700; font-size: 0.9rem; transition: background-color 0.2s ease; cursor: pointer; }
    .btn-confirmar:hover { background-color: #245a7a; color: white; }
    .link-cancelar { color: #aaa; text-decoration: none; font-size: 0.88rem; }
    .link-cancelar:hover { color: #555; text-decoration: underline; }
    .alerta-erro { background-color: #fdecea; color: #F24822; border: 1px solid #F24822; border-radius: 8px; padding: 12px 16px; margin-bottom: 16px; font-weight: 600; }
    .alerta-sucesso { background-color: #e8f5e9; color: #14ae5c; border: 1px solid #14ae5c; border-radius: 8px; padding: 12px 16px; margin-bottom: 16px; font-weight: 600; }
</style>

<div class="sidebar">
    <div class="sidebar-logo">
        <img src="/images/logo.png" alt="Logo" onerror="this.style.display='none'" />
    </div>
    <nav class="sidebar-nav">
        <a href="/produto/index" class="btn-sidebar">Estoque</a>
        <a href="/produto/create" class="btn-sidebar">Novo Produto</a>
        <a href="/produto/movimentar" class="btn-sidebar">Movimentar Estoque</a>
        <a href="/produto/relatorios" class="btn-sidebar">Relatórios</a>
    </nav>
    <hr class="sidebar-divider" />
    <div class="sidebar-footer">
        @if (Context.Session.GetString("UsuarioTipo") == "admin")
        {
            <a href="/Usuario/Index" class="btn-sidebar-link">Gerenciar Usuários</a>
        }
        <a href="/Usuario/TrocarSenha" class="btn-sidebar-link">Trocar Senha</a>
        <a href="/Usuario/Logout" class="btn-sidebar-link btn-sair">Sair</a>
    </div>
</div>

<div class="main-content">
    <div class="main-titulo">Trocar Senha</div>
    <div class="main-subtitulo">Digite sua senha atual e a nova senha</div>

    <div class="card-form">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alerta-sucesso">@TempData["Sucesso"]</div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="alerta-erro">@TempData["Erro"]</div>
        }

        <form method="post" action="/Usuario/TrocarSenha">
            <div class="campo">
                <label class="form-label">Senha Atual</label>
                <input class="form-control" type="password" name="senhaAtual" required />
            </div>
            <div class="campo">
                <label class="form-label">Nova Senha</label>
                <input class="form-control" type="password" name="novaSenha" required />
            </div>
            <div class="acoes">
                <button type="submit" class="btn-confirmar">Salvar</button>
                <a href="/produto/index" class="link-cancelar">Cancelar</a>
            </div>
        </form>
    </div>
</div>